// ── 탭 ───────────────────────────────────────────────────
function renderTabs() {
  document.getElementById("essay-tabs").innerHTML =
    ESSAYS.map((e,i) =>
      `<button class="tab-btn${i===curE?" active":""}" onclick="selectEssay(${i})">${i+1}. ${e.title}</button>`
    ).join("");
}
function selectEssay(i) {
  curE = i;
  document.getElementById("reveal-list").innerHTML = "";
  document.getElementById("complete-banner").classList.remove("visible");
  renderTabs(); renderPassage(); updateScore(); updateRevealBtn();
}

// ── 텍스트 토크나이즈 ─────────────────────────────────────
function escH(s) { return s.replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;"); }
function escA(s) { return s.replace(/\\/g,"\\\\").replace(/'/g,"\\'"); }

function tokenize(text, markers, pi) {
  if (!markers.length) return escH(text);
  const sorted = [...markers].sort((a,b) => b.word.length - a.word.length);
  let segs = [{t:text, isM:false, word:""}];
  for (const m of sorted) {
    const next = [];
    for (const seg of segs) {
      if (seg.isM) { next.push(seg); continue; }
      const parts = seg.t.split(m.word);
      for (let i = 0; i < parts.length; i++) {
        if (parts[i]) next.push({t:parts[i], isM:false, word:""});
        if (i < parts.length-1) next.push({t:m.word, isM:true, word:m.word});
      }
    }
    segs = next;
  }
  return segs.map(seg => {
    if (!seg.isM) return escH(seg.t);
    const k = key(pi, seg.word);
    const st = state[k];
    const rev = revealedEssays[curE];
    let cls = "word-span";
    if (st === "correct") cls += " state-correct";
    else if (rev) cls += " state-revealed";
    const m = markers.find(m => m.word === seg.word);
    const mc = METHOD_COLOR[m.method], mb = METHOD_BG[m.method];
    const badge = (st === "correct" || rev)
      ? `<span class="method-badge" style="background:${mb};color:${mc}">${m.method}</span>` : "";
    const clickable = !rev && st !== "correct";
    return `<span class="${cls}"${clickable ? ` onclick="openPopup(${pi},'${escA(seg.word)}')"` : ""}>${escH(seg.t)}</span>${badge}`;
  }).join("");
}

function renderPassage() {
  document.getElementById("passage").innerHTML =
    ESSAYS[curE].paras.map((p,pi) => `
      <div class="para-card">
        <div class="para-num">문단 ${pi+1}${p.markers.length ? ` — 표지어 ${p.markers.length}개` : ""}</div>
        <div class="para-text">${tokenize(p.text, p.markers, pi)}</div>
      </div>`).join("");
}

// ── 점수 / 버튼 ───────────────────────────────────────────
function updateScore() {
  const found = foundCount(), total = totalMarkers();
  document.getElementById("sc-found").textContent = found;
  document.getElementById("sc-total").textContent = total;
  const pct = total ? Math.round(found/total*100) : 0;
  const msgs = ["표지어를 클릭해 설명 방법을 맞혀 보세요!","잘 찾고 있어요!","절반 이상 찾았어요!","거의 다 왔어요!","모두 맞혔어요! 정답 공개 버튼이 열렸어요."];
  document.getElementById("sc-msg").textContent = msgs[Math.min(Math.floor(pct/25), 4)];
  document.getElementById("complete-banner").classList.toggle("visible", found===total && total>0);
}
function updateRevealBtn() {
  const all = isAllCorrect();
  document.getElementById("reveal-btn").classList.toggle("locked", !all);
  document.getElementById("reveal-icon").className = all ? "ti ti-eye" : "ti ti-lock";
}

// ── 팝업 ─────────────────────────────────────────────────
function openPopup(pi, word) {
  const k = key(pi, word);
  if (state[k] === "correct") return;
  const marker = ESSAYS[curE].paras[pi].markers.find(m => m.word === word);
  if (!marker) return;
  activePopup = {k, pi, word, method: marker.method};
  document.getElementById("pw-word").textContent = `"${word}"`;
  const fb = document.getElementById("pw-feedback");
  fb.style.display = "none"; fb.className = "popup-feedback";
  const wrong = METHODS.filter(m => m !== marker.method).sort(() => Math.random()-.5).slice(0,3);
  const choices = [marker.method, ...wrong].sort(() => Math.random()-.5);
  document.getElementById("pw-grid").innerHTML = choices.map(m => `
    <button class="m-btn" onclick="chooseMethod('${m}')">
      <span class="m-name"><span class="m-dot" style="background:${METHOD_COLOR[m]}"></span>${m}</span>
      <span class="m-core">${METHOD_INFO[m].core}</span>
    </button>`).join("");
  document.getElementById("popup").style.display = "flex";
}
function chooseMethod(chosen) {
  if (!activePopup) return;
  const {k, method} = activePopup;
  const correct = chosen === method;
  document.querySelectorAll(".m-btn").forEach(btn => {
    const nm = btn.querySelector(".m-name");
    const label = nm ? nm.textContent.trim() : "";
    if (label === method) btn.classList.add("correct-ans");
    if (label === chosen && !correct) btn.classList.add("wrong-ans");
    btn.disabled = true;
  });
  const fb = document.getElementById("pw-feedback");
  fb.style.display = "block";
  if (correct) {
    fb.className = "popup-feedback feedback-ok";
    fb.textContent = "✓ 정답이에요!";
    state[k] = "correct";
    setTimeout(() => { closePopup(); renderPassage(); updateScore(); updateRevealBtn(); }, 700);
  } else {
    fb.className = "popup-feedback feedback-no";
    fb.textContent = `✗ 아쉬워요. 정답은 '${method}'예요.`;
  }
}
function onPopupBg(e) { if (e.target===document.getElementById("popup")) closePopup(); }
function closePopup() { document.getElementById("popup").style.display="none"; activePopup=null; }

// ── 정답 공개 / 리셋 ──────────────────────────────────────
function revealAll() {
  if (!isAllCorrect()) {
    const tip = document.getElementById("lock-tip");
    tip.classList.add("visible");
    setTimeout(() => tip.classList.remove("visible"), 2200);
    return;
  }
  revealedEssays[curE] = true;
  renderPassage();
  let rows = "";
  ESSAYS[curE].paras.forEach((p,pi) => {
    p.markers.forEach(m => {
      const mc=METHOD_COLOR[m.method], mb=METHOD_BG[m.method];
      rows += `<div class="ral-row">
        <span class="ral-word">"${m.word}"</span>
        <span class="method-badge" style="background:${mb};color:${mc}">${m.method}</span>
        <span class="ral-check">✓</span>
      </div>`;
    });
  });
  document.getElementById("reveal-list").innerHTML = `
    <div class="reveal-answer-list">
      <div class="ral-head">표지어 전체 정답 목록</div>
      <div class="ral-body">${rows}</div>
    </div>`;
}
function resetAll() {
  ESSAYS[curE].paras.forEach((p,pi) => p.markers.forEach(m => delete state[key(pi,m.word)]));
  delete revealedEssays[curE];
  document.getElementById("reveal-list").innerHTML = "";
  document.getElementById("complete-banner").classList.remove("visible");
  document.getElementById("popup").style.display = "none";
  activePopup = null;
  renderPassage(); updateScore(); updateRevealBtn();
}

// ── init ─────────────────────────────────────────────────
buildGuide(); renderTabs(); renderPassage(); updateScore(); updateRevealBtn();
</script>
</body>

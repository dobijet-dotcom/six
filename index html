// ── 상태 ─────────────────────────────────────────────────
let curE = 0, state = {}, activePopup = null, revealedEssays = {};

function key(pi, word) { return `${curE}-${pi}-${word}`; }
function totalMarkers() { return ESSAYS[curE].paras.reduce((s,p) => s+p.markers.length, 0); }
function foundCount() {
  return ESSAYS[curE].paras.reduce((s,p,pi) =>
    s + p.markers.filter(m => state[key(pi,m.word)] === "correct").length, 0);
}
function isAllCorrect() { return foundCount() === totalMarkers(); }

// ── 안내 박스 ─────────────────────────────────────────────
function buildGuide() {
  document.getElementById("guide-body").innerHTML = METHODS.map(m => `
    <div class="guide-item">
      <div class="g-name" style="color:${METHOD_COLOR[m]}">${m}</div>
      <div class="g-desc">${METHOD_INFO[m].desc}</div>
      <div class="g-marker">${METHOD_INFO[m].core}</div>
    </div>`).join("");
}
function toggleGuide() {
  const b = document.getElementById("guide-body");
  const a = document.getElementById("guide-arrow");

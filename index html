<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>표지어 찾고, 설명 방법 맞히기</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.19.0/tabler-icons.min.css">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --bg:#ffffff; --bg2:#f5f5f4; --bg3:#eeece9;
    --text:#1a1a1a; --text2:#555550; --text3:#999990;
    --border:rgba(0,0,0,.12); --border2:rgba(0,0,0,.22);
    --radius:8px; --radius-lg:12px;
    --info-bg:#e6f1fb; --info-text:#185fa5;
  }
  @media (prefers-color-scheme:dark){
    :root{
      --bg:#1c1c1a; --bg2:#252523; --bg3:#2e2e2b;
      --text:#f0ede8; --text2:#aaa89f; --text3:#666660;
      --border:rgba(255,255,255,.12); --border2:rgba(255,255,255,.22);
      --info-bg:#0c2a45; --info-text:#85b7eb;
    }
  }
  body{font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;background:var(--bg3);color:var(--text);min-height:100vh;padding:1.5rem 1rem 3rem}
  .container{max-width:720px;margin:0 auto}
  h1{font-size:20px;font-weight:500;margin-bottom:4px}
  .subtitle{font-size:13px;color:var(--text2);margin-bottom:1.25rem}

  /* 설명 방법 안내 박스 */
  .guide-box{border:0.5px solid var(--border);border-radius:var(--radius);background:var(--bg2);margin-bottom:1.25rem;overflow:hidden}
  .guide-toggle{width:100%;padding:9px 14px;background:none;border:none;cursor:pointer;text-align:left;font-size:13px;color:var(--text2);display:flex;align-items:center;gap:6px}
  .guide-toggle:hover{background:var(--bg3)}
  .guide-body{padding:10px 14px 12px;display:none;grid-template-columns:1fr 1fr;gap:6px}
  .guide-body.open{display:grid}
  .guide-item{padding:7px 10px;border-radius:var(--radius);border:0.5px solid var(--border);background:var(--bg)}
  .guide-item .g-name{font-size:12px;font-weight:500;margin-bottom:2px}
  .guide-item .g-desc{font-size:11px;color:var(--text2);line-height:1.5}
  .guide-item .g-marker{font-size:11px;color:var(--text3);margin-top:2px;font-style:italic}

  .essay-tabs{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:1rem}
  .tab-btn{padding:5px 13px;border-radius:14px;border:0.5px solid var(--border2);background:var(--bg);font-size:12px;cursor:pointer;color:var(--text2);transition:all .15s}
  .tab-btn:hover{background:var(--bg2)}
  .tab-btn.active{background:var(--text);color:var(--bg);border-color:var(--text)}

  .complete-banner{padding:11px 16px;border-radius:var(--radius);background:#eaf3de;border:0.5px solid #3b6d11;font-size:14px;color:#3b6d11;font-weight:500;margin-bottom:1rem;display:none;align-items:center;gap:8px}
  .complete-banner.visible{display:flex}

  .score-bar{display:flex;align-items:center;gap:10px;margin-bottom:1rem;padding:10px 14px;border-radius:var(--radius);background:var(--bg2);border:0.5px solid var(--border);flex-wrap:wrap}
  .sc-block{text-align:center;min-width:48px}
  .sc-num{font-size:22px;font-weight:500}
  .sc-lbl{font-size:11px;color:var(--text2)}
  .sc-divider{width:1px;height:32px;background:var(--border)}
  .sc-msg{font-size:13px;color:var(--text2);flex:1}

  .action-row{display:flex;gap:8px;margin-bottom:1.25rem;flex-wrap:wrap;align-items:center}
  .act-btn{padding:7px 16px;border-radius:var(--radius);border:0.5px solid var(--border2);background:var(--bg);font-size:13px;cursor:pointer;color:var(--text);display:inline-flex;align-items:center;gap:5px;transition:background .12s}
  .act-btn:hover{background:var(--bg2)}
  .act-btn:active{transform:scale(.98)}
  .act-btn.locked{border-color:var(--border);color:var(--text3)}
  .lock-tip{font-size:12px;color:var(--text3);padding:6px 10px;border-radius:var(--radius);background:var(--bg2);border:0.5px solid var(--border);display:none;align-items:center;gap:5px}
  .lock-tip.visible{display:inline-flex}

  .passage{display:flex;flex-direction:column;gap:12px}
  .para-card{padding:13px 15px;border-radius:var(--radius);border:0.5px solid var(--border);background:var(--bg)}
  .para-num{font-size:11px;color:var(--text3);margin-bottom:6px}
  .para-text{font-size:14px;line-height:1.85;color:var(--text)}

  .word-span{cursor:pointer;border-radius:3px;padding:1px 2px;border-bottom:1.5px solid transparent;transition:background .1s}
  .word-span:hover{background:var(--info-bg);border-bottom-color:var(--info-text)}
  .word-span.state-correct{background:#eaf3de;color:#3b6d11;font-weight:500;border-bottom:2px solid #3b6d11;cursor:default}
  .word-span.state-revealed{background:#fff3cd;color:#856404;font-weight:500;border-bottom:2px solid #ba7517;cursor:default}
  .method-badge{display:inline-block;padding:1px 6px;border-radius:8px;font-size:11px;font-weight:500;margin-left:3px;vertical-align:middle}

  .popup-wrap{position:fixed;inset:0;background:rgba(0,0,0,.4);display:flex;align-items:center;justify-content:center;z-index:999}
  .popup{background:var(--bg);border:0.5px solid var(--border2);border-radius:var(--radius-lg);padding:20px 22px;width:min(360px,92vw)}
  .popup-word{font-size:17px;font-weight:500;margin-bottom:3px}
  .popup-sub{font-size:12px;color:var(--text3);margin-bottom:14px}
  .method-grid{display:grid;grid-template-columns:1fr 1fr;gap:7px}
  .m-btn{padding:9px 8px;border-radius:var(--radius);border:0.5px solid var(--border2);background:var(--bg);font-size:13px;cursor:pointer;color:var(--text2);text-align:left;transition:all .12s;display:flex;flex-direction:column;gap:2px}
  .m-btn:hover{background:var(--bg2)}
  .m-btn .m-name{font-size:13px;display:flex;align-items:center;gap:5px}
  .m-btn .m-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
  .m-btn .m-core{font-size:11px;color:var(--text3);font-style:italic;padding-left:13px}
  .m-btn.correct-ans{background:#eaf3de;border-color:#3b6d11;color:#3b6d11}
  .m-btn.correct-ans .m-core{color:#5a9a5a}
  .m-btn.wrong-ans{background:#faece7;border-color:#993c1d;color:#993c1d}
  .popup-feedback{margin-top:10px;padding:9px 12px;border-radius:var(--radius);font-size:13px;text-align:center;display:none}
  .feedback-ok{background:#eaf3de;color:#3b6d11}
  .feedback-no{background:#faece7;color:#993c1d}
  .popup-close{margin-top:12px;width:100%;padding:8px;border-radius:var(--radius);border:0.5px solid var(--border);background:var(--bg);font-size:13px;cursor:pointer;color:var(--text2)}
  .popup-close:hover{background:var(--bg2)}

  .reveal-answer-list{margin-top:1.5rem;border:0.5px solid var(--border);border-radius:var(--radius-lg);overflow:hidden}
  .ral-head{padding:9px 14px;background:var(--bg2);border-bottom:0.5px solid var(--border);font-size:13px;font-weight:500}
  .ral-body{padding:12px 14px;display:flex;flex-direction:column;gap:6px}
  .ral-row{display:flex;align-items:center;gap:10px;padding:6px 10px;border-radius:var(--radius);background:var(--bg2);font-size:13px}
  .ral-word{font-weight:500;min-width:120px}
  .ral-check{margin-left:auto;font-size:12px;color:#3b6d11}
</style>
</head>
<body>
<div class="container">
  <h1>표지어 찾고, 설명 방법 맞히기</h1>
  <p class="subtitle">설명문에서 표지어를 클릭하고, 어떤 설명 방법인지 맞혀 보세요. 모두 맞혀야 정답을 확인할 수 있어요!</p>

  <!-- 설명 방법 안내 -->
  <div class="guide-box">
    <button class="guide-toggle" onclick="toggleGuide()">
      <i class="ti ti-book-2"></i> 8가지 설명 방법 보기 <i class="ti ti-chevron-down" id="guide-arrow"></i>
    </button>
    <div class="guide-body" id="guide-body"></div>
  </div>

  <div class="essay-tabs" id="essay-tabs"></div>

  <div class="complete-banner" id="complete-banner">
    <i class="ti ti-circle-check"></i>
    모든 표지어를 맞혔어요! 이제 정답 목록을 확인할 수 있어요.
  </div>

  <div class="score-bar">
    <div class="sc-block"><div class="sc-num" id="sc-found">0</div><div class="sc-lbl">맞힘</div></div>
    <div class="sc-divider"></div>
    <div class="sc-block"><div class="sc-num" id="sc-total">0</div><div class="sc-lbl">전체</div></div>
    <div class="sc-divider"></div>
    <div class="sc-msg" id="sc-msg">표지어를 클릭해 설명 방법을 맞혀 보세요!</div>
  </div>

  <div class="action-row">
    <button class="act-btn locked" id="reveal-btn" onclick="revealAll()">
      <i class="ti ti-lock" id="reveal-icon"></i>
      <span id="reveal-label">정답 공개</span>
    </button>
    <button class="act-btn" onclick="resetAll()"><i class="ti ti-refresh"></i> 다시하기</button>
    <span class="lock-tip" id="lock-tip"><i class="ti ti-info-circle"></i> 표지어를 모두 맞혀야 열려요</span>
  </div>

  <div class="passage" id="passage"></div>
  <div id="reveal-list"></div>
</div>

<div class="popup-wrap" id="popup" style="display:none" onclick="onPopupBg(event)">
  <div class="popup">
    <div class="popup-word" id="pw-word"></div>
    <div class="popup-sub">이 표지어는 어떤 설명 방법인가요?</div>
    <div class="method-grid" id="pw-grid"></div>
    <div class="popup-feedback" id="pw-feedback"></div>
    <button class="popup-close" onclick="closePopup()">닫기</button>
  </div>
</div>

<script>
// ── 설명 방법 정의 ─────────────────────────────────────────
// 분류: 여러 대상을 공통 속성으로 묶어 그룹을 만듦 → "묶는다"
// 구분: 하나의 대상을 기준에 따라 나눔            → "나눈다"
const METHOD_INFO = {
  "정의": { core:"~이란, ~을 말한다",    desc:"대상의 뜻이나 본질을 밝힘" },
  "예시": { core:"예를 들면, 예컨대",    desc:"구체적 사례를 들어 설명함" },
  "비교": { core:"마찬가지로, 공통점",   desc:"둘 이상 대상의 공통점을 밝힘" },
  "대조": { core:"이와 다르게, 반면",    desc:"둘 이상 대상의 차이점을 밝힘" },
  "분류": { core:"~로 묶인다, ~에 속한다", desc:"여러 대상을 공통 속성으로 묶어 그룹을 만듦" },
  "구분": { core:"~로 나뉜다, 기준으로", desc:"하나의 대상을 기준에 따라 나눔" },
  "인과": { core:"때문에, 그 결과",      desc:"원인과 결과의 관계를 밝힘" },
  "분석": { core:"로 구성된다, 로 이루어진다", desc:"구성 요소나 부분으로 나눠 설명함" },
};
const METHODS = Object.keys(METHOD_INFO);
const METHOD_COLOR = {
  "정의":"#534AB7","예시":"#0F6E56","비교":"#185FA5","대조":"#993C1D",
  "분류":"#993556","구분":"#BA7517","인과":"#639922","분석":"#A32D2D"
};
const METHOD_BG = {
  "정의":"#EEEDFE","예시":"#E1F5EE","비교":"#E6F1FB","대조":"#FAECE7",
  "분류":"#FBEAF0","구분":"#FAEEDA","인과":"#EAF3DE","분석":"#FADBD8"
};

// ── 설명문 데이터 ──────────────────────────────────────────
// 분류/구분 적용 원칙:
//   분류: 여러 종류의 것들을 어떤 기준으로 묶어 카테고리를 세울 때
//         예) 동물을 포유류·조류·파충류로 분류 / 도서관 종류를 유형별로 분류
//   구분: 하나의 대상(전체)을 기준에 따라 쪼갤 때
//         예) 미세먼지를 크기에 따라 PM10과 PM2.5로 구분
//         예) 물의 순환을 육지 순환과 바다 순환으로 구분
const ESSAYS = [
 {
  title:"미세먼지란 무엇인가", sub:"과학·환경",
  paras:[
   {
    text:"날씨 예보를 보다가 '미세먼지 나쁨'이라는 문구가 자주 눈에 띈다. 우리가 숨 쉴 때마다 들이마시는 공기 속에 어떤 물질이 들어 있는지 궁금했던 적이 있을 것이다. 이 글에서는 미세먼지의 정의와 종류, 건강에 미치는 영향을 알기 쉽게 설명하고자 한다.",
    markers:[]
   },
   {
    // 정의: '미세먼지란 ~이다' → 정의
    text:"미세먼지란 지름이 10마이크로미터(㎛) 이하인 아주 작은 먼지 입자를 가리킨다. 이처럼 눈에 보이지 않을 만큼 미세한 입자는 공기 중에 오랫동안 떠다니는 특성이 있다.",
    markers:[{word:"미세먼지란",method:"정의"}]
   },
   {
    // 구분: 미세먼지(하나의 대상)를 크기 기준으로 PM10/PM2.5로 나눔 → 구분
    // 구분: 발생 원인(하나의 대상)을 인위적/자연적으로 나눔 → 구분
    text:"미세먼지는 크기를 기준으로 지름 10㎛ 이하인 미세먼지(PM10)와 지름 2.5㎛ 이하인 초미세먼지(PM2.5)로 구분된다. 또한 발생 원인을 기준으로 자동차 매연·공장 굴뚝 같은 인위적 원인과 황사·화산재 같은 자연적 원인으로 나눌 수 있다.",
    markers:[
     {word:"기준으로",method:"구분"},
     {word:"구분된다",method:"구분"},
     {word:"나눌 수 있다",method:"구분"}
    ]
   },
   {
    // 인과: 작기 때문에 → 그 결과
    text:"초미세먼지는 크기가 매우 작기 때문에 코와 기관지에서 걸러지지 않고 폐 깊숙이 침투한다. 그 결과 호흡기 질환과 심혈관 질환을 일으킬 수 있다.",
    markers:[
     {word:"때문에",method:"인과"},
     {word:"그 결과",method:"인과"}
    ]
   },
   {
    // 예시: 예를 들면
    text:"예를 들면, 미세먼지 농도가 '나쁨' 수준인 날에는 어린이와 노인이 야외 활동을 자제하도록 권고된다. 또한 마스크를 착용하지 않으면 목이 따갑거나 기침이 나는 증상이 나타나기도 한다.",
    markers:[{word:"예를 들면",method:"예시"}]
   },
   {
    text:"지금까지 살펴보았듯이, 미세먼지는 크기에 따라 구분되며 그 크기가 작을수록 건강에 미치는 영향이 크다. 대기질 지수를 확인하고 마스크를 착용하는 습관이 우리 건강을 지키는 첫걸음이 될 것이다.",
    markers:[]
   }
  ]
 },
 {
  title:"스마트폰의 구조와 영향", sub:"기술·사회",
  paras:[
   {
    text:"우리나라 청소년의 하루 평균 스마트폰 사용 시간은 약 4.5시간에 달한다. 이처럼 일상 깊숙이 자리 잡은 스마트폰이 어떤 구조로 이루어져 있고, 우리 생활에 어떤 영향을 미치는지 살펴보고자 한다.",
    markers:[]
   },
   {
    // 정의: 스마트폰이란
    // 분석: 하드웨어와 소프트웨어로 구성(전체를 요소로 쪼갬)
    text:"스마트폰이란 통화 기능에 컴퓨터의 연산 기능을 결합한 휴대용 기기이다. 스마트폰은 크게 하드웨어와 소프트웨어로 구성된다. 하드웨어에는 화면, 배터리, 카메라, 프로세서가 포함되며, 소프트웨어에는 운영 체제(OS)와 각종 애플리케이션이 있다.",
    markers:[
     {word:"스마트폰이란",method:"정의"},
     {word:"로 구성된다",method:"분석"}
    ]
   },
   {
    // 비교: 마찬가지로 / 대조: 이와 다르게, 반면
    text:"스마트폰과 기존 휴대전화는 마찬가지로 통화와 문자 전송이 가능하며, 둘 다 휴대하기 편한 소형 기기라는 공통점이 있다. 이와 다르게, 기존 휴대전화는 통화·문자만 지원하는 반면 스마트폰은 인터넷, 동영상, 내비게이션 등 수백 가지 기능을 수행한다.",
    markers:[
     {word:"마찬가지로",method:"비교"},
     {word:"이와 다르게",method:"대조"},
     {word:"반면",method:"대조"}
    ]
   },
   {
    // 인과: 늘어난 결과 / 예시: 예를 들면
    text:"스마트폰 사용이 늘어난 결과, 언제 어디서나 정보에 접근하기 편리해졌다. 그러나 지나친 사용은 수면 장애나 집중력 저하를 일으키기도 한다. 예를 들면, 잠들기 전 스마트폰을 사용하면 블루라이트가 수면 호르몬 분비를 방해한다.",
    markers:[
     {word:"늘어난 결과",method:"인과"},
     {word:"예를 들면",method:"예시"}
    ]
   },
